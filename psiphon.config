# Server to connect to (use Psiphon endpoint)
serverUrl = "https://tunnel.psiphon3.com"
# Port for control interface (unused by default)
controlPort = 0
# Enable logging to stdout
logToStdout = true
# Verbosity level (0=errors, 1=warnings, 2=info, 3=debug)
logVerbosity = 2
# Reconnect automatically if disconnected
autoReconnect = true
# Specify region codes (e.g., US, CA, UK). Empty = auto-select
#regionCodes = "US,CA,UK"

# Network interface binding (0.0.0.0 for all)
bindAddress = "0.0.0.0"
# Local SOCKS proxy port
socksPort = 1080
# Local HTTP proxy port
httpPort = 8081
# DNS fallback (use system DNS when Psiphon unavailable)
enableDnsFallback = true
